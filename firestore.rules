rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitive Definition ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens never contain custom claims in this environment, use DB lookup
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.lower() == "musicdistributionindia.in@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'artist') in ['admin', 'content_manager', 'finance_admin', 'support'])
      );
    }
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "musicdistributionindia.in@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.role in ['artist', 'admin', 'content_manager', 'finance_admin', 'support'] &&
             data.walletBalance is number &&
             data.status in ['active', 'suspended'] &&
             data.createdAt is string;
    }

    function isValidRelease(data) {
      return data.userId is string &&
             data.title is string && data.title.size() <= 256 &&
             data.artist is string && data.artist.size() <= 128 &&
             data.status is string &&
             data.createdAt is string;
    }

    function isValidWithdrawal(data) {
      return data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 500 &&
             data.method in ['UPI', 'Bank'] &&
             data.status in ['pending', 'completed', 'rejected'] &&
             data.createdAt is string;
    }

    function isValidNotification(data) {
      return data.title is string && data.title.size() <= 128 &&
             data.message is string && data.message.size() <= 512 &&
             data.type in ['info', 'warning', 'urgent'] &&
             data.createdAt is string;
    }

    function isValidSupportTicket(data) {
      return data.userId == request.auth.uid &&
             data.subject is string && data.subject.size() <= 256 &&
             data.message is string && data.message.size() <= 2048 &&
             data.status in ['pending', 'resolved'] &&
             data.createdAt is string;
    }

    // --- Collection Rules ---

    // Broadcast Notifications
    match /system_notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidNotification(incoming());
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidSupportTicket(incoming()) && (incoming().userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // System Config
    match /system/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users: Highly sensitive PII
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().walletBalance == 0;
      allow update: if (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phone', 'photoURL'])) || isAdmin();
    }

    // Artists & Labels
    match /artists/{artistId} {
      allow read: if isSignedIn();
      allow create: if isOwner(incoming().userId);
      allow update, delete: if isOwner(existing().userId) || isAdmin();
    }

    match /labels/{labelId} {
      allow read: if isSignedIn();
      allow create: if isOwner(incoming().userId);
      allow update, delete: if isOwner(existing().userId) || isAdmin();
    }

    // Releases: The Core Engine
    match /releases/{releaseId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isOwner(incoming().userId) && isValidRelease(incoming()) && incoming().status == 'pending';
      
      allow update: if (
        // Action: User correction/edit before live
        (isOwner(existing().userId) && existing().status in ['pending', 'action_required'] && 
         isValidRelease(incoming()) && 
         incoming().status == 'pending' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'artist', 'singerName', 'instagramId', 'lyricist', 'lyrics', 'composer', 'producer', 'copyright', 'publisher', 'language', 'primaryGenre', 'secondaryGenre', 'releaseDate', 'releaseTime', 'label', 'audioUrl', 'coverUrl', 'selectedPlatforms'])) ||
        
        // Action: User request takedown
        (isOwner(existing().userId) && existing().status == 'live' &&
         incoming().status == 'takedown_requested' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
         
        // Action: Admin Master Review
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    // Withdrawals
    match /withdrawals/{withdrawalId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(incoming().userId) && isValidWithdrawal(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    // Transactions: Internal platform ledger
    match /transactions/{transactionId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // OAC & Content ID Requests
    match /oac_requests/{requestId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(incoming().userId) && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    // Content ID Requests
    match /content_id_requests/{requestId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(incoming().userId) && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    // Royalty Reports: Strictly private
    match /royalty_reports/{reportId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Admin Logs: Super Admin only
    match /admin_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin();
    }

    // Static Admin UIDs
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }
  }
}
